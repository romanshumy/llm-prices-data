{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.modelpricewatch/mcp",
  "description": "Live LLM API pricing: token prices, comparisons, cheapest-model lookups. No key required.",
  "websiteUrl": "https://modelpricewatch.com/api/",
  "version": "1.0.0",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://modelpricewatch.com/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@modelpricewatch/mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
